{
  "name": "markm",
  "version": "0.1.0",
  "description": "A fast, themeable native Linux markdown viewer with an edit mode",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "app": "neu run",
    "start": "vite build && neu run",
    "neu:update": "neu update",
    "package": "vite build && neu build --release",
    "package:macos-app": "scripts/package-macos-app.sh"
  },
  "devDependencies": {
    "@neutralinojs/neu": "^11.3.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "svelte": "^5.19.0",
    "vite": "^6.0.7"
  },
  "dependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language": "^6.10.8",
    "@codemirror/state": "^6.5.1",
    "@codemirror/view": "^6.36.2",
    "@lezer/highlight": "^1.2.1",
    "codemirror": "^6.0.1",
    "diff": "^5.2.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0"
  }
}
