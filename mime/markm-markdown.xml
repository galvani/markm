<?xml version="1.0" encoding="UTF-8"?>
<!-- Ensures Markdown extensions resolve to text/markdown even where the
     system's shared-mime-info is old or lacks it. Installed to
     $PREFIX/share/mime/packages/ by scripts/install.sh. -->
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">
  <mime-type type="text/markdown">
    <comment>Markdown document</comment>
    <glob pattern="*.md"/>
    <glob pattern="*.markdown"/>
    <glob pattern="*.mdown"/>
    <glob pattern="*.mkd"/>
    <glob pattern="*.mkdn"/>
    <sub-class-of type="text/plain"/>
  </mime-type>
</mime-info>
