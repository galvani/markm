{
  "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
  "applicationId": "app.markm",
  "applicationName": "markm",
  "description": "A fast, themeable native markdown viewer with an edit mode",
  "applicationIcon": "public/icons/appIcon.png",
  "version": "0.1.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/dist/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": true,
    "writeToLogFile": true
  },
  "nativeAllowList": [
    "app.*",
    "os.*",
    "window.*",
    "events.*",
    "filesystem.*",
    "storage.*",
    "computer.*",
    "debug.log"
  ],
  "modes": {
    "window": {
      "title": "markm",
      "width": 960,
      "height": 720,
      "minWidth": 640,
      "minHeight": 400,
      "center": true,
      "fullScreen": false,
      "alwaysOnTop": false,
      "icon": "/dist/icons/appIcon.png",
      "enableInspector": false,
      "borderless": false,
      "maximize": false,
      "hidden": false,
      "resizable": true,
      "exitProcessOnClose": false
    }
  },
  "cli": {
    "binaryName": "markm",
    "resourcesPath": "/dist/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/dist/neutralino.js",
    "binaryVersion": "6.8.0",
    "clientVersion": "6.8.0"
  }
}
